generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String    @default("")
  alias         String?
  avatarUrl     String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  groupPredictions    GroupPrediction[]
  bracketPredictions  BracketPrediction[]
  bonusPredictions    BonusPrediction[]
  accounts      Account[]
  sessions      Session[]
  resetRequests PasswordResetRequest[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id       String @id @default(cuid())
  name     String @unique
  code     String @unique
  flagUrl  String @default("")
  groupId  String
  group    Group  @relation(fields: [groupId], references: [id])
}

model Group {
  id     String @id @default(cuid())
  name   String @unique
  teams  Team[]
}

model Deadline {
  id        String   @id @default(cuid())
  phase     String   @unique
  closesAt  DateTime
  label     String   @default("")
}

model GroupPrediction {
  id          String @id @default(cuid())
  userId      String
  groupId     String
  positions   String
  wins        String?  // JSON: {"TeamName": predictedWins, ...}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, groupId])
  @@index([userId])
}

model BracketPrediction {
  id         String @id @default(cuid())
  userId     String
  round      String
  matchIndex Int
  teamName   String
  scoreA     Int?   // predicted goals for team A (first listed team)
  scoreB     Int?   // predicted goals for team B (second listed team)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, round, matchIndex])
  @@index([userId])
}

model ActualGroupResult {
  id        String @id @default(cuid())
  groupId   String @unique
  positions String
  wins      String?  // JSON: {"TeamName": actualWins, ...}
  updatedAt DateTime @updatedAt
}

model ActualBracketResult {
  id         String @id @default(cuid())
  round      String
  matchIndex Int
  teamName   String
  scoreA     Int?   // actual goals for team A
  scoreB     Int?   // actual goals for team B
  updatedAt  DateTime @updatedAt
  @@unique([round, matchIndex])
}

model BracketMatchup {
  id         String @id @default(cuid())
  round      String
  matchIndex Int
  teamA      String
  teamB      String
  updatedAt  DateTime @updatedAt
  @@unique([round, matchIndex])
}

// Bonus quiz questions defined by admin
model BonusQuestion {
  id           String   @id @default(cuid())
  slug         String   @unique // e.g. "top_scorer", "least_goals_conceded"
  question     String   // display text
  type         String   // "player", "team", "yesno", "number"
  points       Int      @default(5)
  answer       String?  // actual answer set by admin after tournament
  validOptions String?  // for text questions: valid answers separated by # (e.g. "Messi#Mbappé#Haaland")
  closesAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  predictions  BonusPrediction[]
}

model PasswordResetRequest {
  id          String   @id @default(cuid())
  userId      String
  message     String   @default("")
  status      String   @default("PENDING") // PENDING, APPROVED, DENIED
  newPassword String?  // admin sets this when approving
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([status])
}

model BonusPrediction {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  answer      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question    BonusQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  @@unique([userId, questionId])
  @@index([userId])
}

model AppConfig {
  id        String   @id @default("singleton")
  data      String   @db.Text // JSON blob with scoring + prizes
  updatedAt DateTime @updatedAt
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  note      String   @default("")
  usedBy    String?
  usedAt    DateTime?
  createdAt DateTime @default(now())
  @@index([code])
}